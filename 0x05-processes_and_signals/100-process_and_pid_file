#!/usr/bin/env bash
#This creates, displays and deletes

PIDFILE="/var/run/myscript.pid"

echo $$ | sudo tee "$PIDFILE" > /dev/null

cleanup() {
    sudo rm -f "$PIDFILE"
    exit 0
}

trap 'echo "I hate the kill command"; cleanup' SIGTERM
trap 'echo "Y U no love me?!"; cleanup' SIGINT
trap 'cleanup' SIGQUIT EXIT

while true
do
    echo "To infinity and beyond"
    sleep 2
done